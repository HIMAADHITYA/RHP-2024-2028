#include <iostream>
using namespace std;

int main() {
    string s;
    cin >> s;

    bool present[26] = {false};

    for (char ch : s) {
        present[ch - 'a'] = true;
    }

    bool check = true;

    for (int i = 0; i < 26; i++) {
        if (!present[i]) {
            check = false;
            break;
        }
    }

    if (check)
        cout << "Yes";
    else
        cout << "No";

    return 0;
}
